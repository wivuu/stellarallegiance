# Copy to .env and fill in — `docker compose` reads this file automatically.
# NEVER commit the filled-in .env (it holds secrets); .env is gitignored.

# Shared secret for the join-token HMAC. Generate a strong one:
#     openssl rand -hex 32
# It MUST match the secret you install in the module:
#     spacetime call stellar-allegiance set_sim_endpoint '"wss://your-host/game"' '"<this value>"'
# With this unset/empty the sim server runs in DEV mode (auth disabled) — never expose that.
SIM_SECRET=

# SpacetimeDB database name the sim server reports match results to.
STDB_DB=stellar-allegiance

# Bearer token of the DB-owner identity, so the sim server's end-of-match writeback
# (report_match_result, which is owner-gated) is authorized. Leave empty to disable
# writeback (the sim logs a one-time skip and keeps running).
STDB_TOKEN=

# Optional overrides (defaults shown):
# STDB_IMAGE=clockworklabs/spacetime
# STDB_PORT=3000
# SIM_PORT=8090
