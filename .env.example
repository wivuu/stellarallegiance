# Copy to .env and fill in — `docker compose` reads this file automatically.
# NEVER commit the filled-in .env (it holds secrets); .env is gitignored.

# Optional shared-secret password. Generate a strong one:
#     openssl rand -hex 32
# Every client's Hello must then carry the same secret (the client reads SIM_SECRET too).
# Leave empty for an OPEN server (LAN / dev) — never expose an open server to untrusted networks.
SIM_SECRET=

# Set to 1 to skip the lobby ready-up and run a perpetual match (bots / benchmarking).
SIM_AUTOSTART=

# Optional override (default shown):
# SIM_PORT=8090

# ---- Public lobby (server discovery + WebRTC NAT traversal) ----

# Set a 3-50 char name to PUBLISH this server to the public lobby so clients can discover and
# WebRTC-join it (works behind NAT, no port-forwarding). Leave empty to stay private (direct only).
SIM_PUBLIC_NAME=

# Where the lobby (server-share) lives. Inside compose the default service name works; for a
# remote lobby set host:port. The Godot client reads PUBLIC_LOBBY too (default 192.168.1.101:8091).
# PUBLIC_LOBBY=server-share:8091

# Optional direct ws:// fallback (host:port) advertised in the listing, if you port-forwarded 8090.
SIM_PUBLIC_ENDPOINT=

# server-share listen port (host side).
# SHARE_PORT=8091

# ICE config the lobby hands to clients/servers. Point at the coturn box's PUBLICLY reachable
# address in production; leave empty for LAN/dev (host-candidate / P2P only, no TURN relay).
#     STUN_URL=stun:lobby.example.com:3478
#     TURN_URL=turn:lobby.example.com:3478
STUN_URL=
TURN_URL=
TURN_USER=wivuu
TURN_PASS=changeme
# TURN_PORT=3478
