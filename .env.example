# Copy to .env and fill in — `docker compose` reads this file automatically.
# NEVER commit the filled-in .env (it holds secrets); .env is gitignored.

# Optional shared-secret password. Generate a strong one:
#     openssl rand -hex 32
# Every client's Hello must then carry the same secret (the client reads SIM_SECRET too).
# Leave empty for an OPEN server (LAN / dev) — never expose an open server to untrusted networks.
SIM_SECRET=

# Set to 1 to skip the lobby ready-up and run a perpetual match (bots / benchmarking).
SIM_AUTOSTART=

# Optional override (default shown):
# SIM_PORT=8090

# ---- Public lobby (server discovery + NAT traversal) ----

# Set a 3-50 char name to PUBLISH this server to the public lobby so clients can discover it. The
# lobby then PROBES this server's port: if it's reachable, clients join DIRECTLY over WebSocket
# (best — forward the port!); if not, they fall back to WebRTC + STUN (some NATs won't connect).
# Leave empty to stay private (joinable only by typing its address).
SIM_PUBLIC_NAME=

# Where the lobby (server-share) lives. Inside compose the default service name works; for a
# remote lobby set host:port. The Godot client reads PUBLIC_LOBBY too (default 192.168.1.101:8091).
# PUBLIC_LOBBY=server-share:8091

# Public-facing port the lobby probes/advertises. Defaults to the listen port (SIM_PORT); set it
# only when a port-forward maps a different external port to this server.
# SIM_PUBLIC_PORT=8090

# Optional host:port this server asserts as its reachable address (e.g. the host's LAN/public
# address when it's behind container NAT or a reverse proxy). The lobby probes it and advertises it
# only if it answers /health. Unset = the lobby uses the registration source IP. Dockerized
# single-box deploys typically need this (the source IP would be the 172.x container IP).
SIM_PUBLIC_ENDPOINT=

# server-share listen port (host side).
# SHARE_PORT=8091

# STUN handed to clients/servers for the WebRTC fallback (when a server isn't directly reachable).
# A public STUN is fine — no need to host one. Default is Cloudflare's; list several (comma- or
# space-separated) as fallbacks. There is NO TURN relay (the lobby never carries game traffic).
# STUN_URL=stun:stun.cloudflare.com:3478,stun:stun.l.google.com:19302
