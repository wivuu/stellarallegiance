<Project Sdk="Microsoft.NET.Sdk.Web">
  <!-- Phase-1 native sim server (see ~/.claude plan replicated-purring-duckling / HANDOFF):
       owns the 20 Hz authoritative match simulation in plain process memory and streams
       AOI-filtered binary snapshots over WebSocket. SpacetimeDB is no longer in the hot
       path; it keeps lobby/defs/persistence and (later) mints join tokens for this server.
       References the same shared deterministic FlightModel the module and Godot client
       compile, so prediction math stays bit-identical across all three. -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <InvariantGlobalization>true</InvariantGlobalization>
    <ServerGarbageCollection>true</ServerGarbageCollection>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../shared/Shared.csproj" />
  </ItemGroup>
</Project>
