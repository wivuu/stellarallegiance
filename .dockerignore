# The sim-server image only needs shared/ and server/ (see server/Dockerfile). Keep the
# build context tiny + reproducible by excluding everything else, build outputs, and local
# state. (The Dockerfile copies shared/ and server/ explicitly, so excluding the rest here
# just speeds up the context upload.)
.git
.github
.vscode
.opencode
.copilot
.claude
**/bin
**/obj
**/.godot
graphify-out
build
client
docs
tests
tools
module
scripts
deploy
.stdb-data
.stdb-config
.PLAN
*.md
.env
.DS_Store
