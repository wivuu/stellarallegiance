# The sim-server image needs shared/, server/, and the canonical GLB assets it loads for
# server-side collision: client/assets/bases and client/assets/asteroids (see server/Dockerfile).
# Keep the build context tiny + reproducible by excluding everything else, build outputs, and
# local state. (The Dockerfile copies what it needs explicitly, so excluding the rest here just
# speeds up the context upload.)
.git
.github
.vscode
.opencode
.copilot
.claude
**/bin
**/obj
**/.godot
graphify-out
build
# Exclude client/ but keep the GLB asset dirs the sim-server's Dockerfile copies.
client/*
!client/assets
client/assets/*
!client/assets/bases
!client/assets/asteroids
docs
tests
tools
module
scripts
deploy
.stdb-data
.stdb-config
.PLAN
*.md
.env
.DS_Store
