{
    // Shared workspace settings (safe to commit). Machine-specific paths do NOT belong here —
    // set them in your USER settings so they aren't committed. See README → "Dev setup".

    // Let the "Godot: import assets (if needed)" folderOpen task run automatically so a
    // fresh clone regenerates the gitignored GLB import artifacts without manual steps.
    "task.allowAutomaticTasks": "on",

    // Godot (.NET/"mono") *executable* used by the VS Code tasks (run/export/import). Left
    // empty on purpose — override it in your User settings (Cmd/Ctrl+, → "godot.executablePath")
    // so your local path isn't committed. When empty, the scripts auto-detect Godot from PATH
    // and standard install locations, so most setups need no value here.
    //   macOS:   "/Applications/Godot_mono.app/Contents/MacOS/Godot"
    //   Windows: "C:/Program Files/Godot_mono/Godot_v4.6.3-stable_mono_win64.exe"
    //   on PATH: "godot-mono"
    "godot.executablePath": ""

    // The godot-tools extension also needs your Godot path for editor/debug integration; set
    // "godotTools.editorPath.godot4" in your User settings too (it wants the .app/.exe path).
}