{
    // Project scripts, exposed as VS Code tasks. Run them with
    //   Cmd/Ctrl+Shift+P → "Tasks: Run Task"
    //
    // All tasks run through `pwsh` (PowerShell Core), which is cross-platform.
    // Install it from https://aka.ms/powershell if it isn't already on your PATH.
    // The Godot executable is taken from the `godot.executablePath` setting (set it
    // in your *User* settings so it isn't committed — see README → Dev setup);
    // when empty the scripts auto-detect Godot from PATH and standard install locations.
    "version": "2.0.0",
    "options": {
        "env": { "GODOT": "${config:godot.executablePath}" }
    },
    "tasks": [
        {
            "label": "Godot: import assets (if needed)",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NonInteractive", "-File",
                "${workspaceFolder}/tools/godot-import.ps1"
            ],
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Godot: reimport assets (force)",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NonInteractive", "-File",
                "${workspaceFolder}/tools/godot-import.ps1",
                "-Force"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run server",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NonInteractive", "-File",
                "${workspaceFolder}/scripts/run-server.ps1"
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "run"
            },
            "problemMatcher": []
        },
        {
            "label": "Run client",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NonInteractive", "-File",
                "${workspaceFolder}/scripts/run-client.ps1"
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "run"
            },
            "problemMatcher": []
        },
        {
            "label": "Export clients (all platforms)",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NonInteractive", "-File",
                "${workspaceFolder}/scripts/export-clients.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Asteroid-gen: build catalog",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NonInteractive", "-File",
                "${workspaceFolder}/tools/asteroid-gen/build.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
