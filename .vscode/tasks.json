{
    // Project scripts, exposed as VS Code tasks. Run them with
    //   Cmd/Ctrl+Shift+P → "Tasks: Run Task"
    //
    // All tasks run through PowerShell 7+ (`pwsh`), which must be on PATH (cross-platform:
    // Windows/macOS/Linux). The scripts auto-detect Godot from PATH and standard install
    // locations; to pin a non-standard path per-workstation, run the "Godot: set executable
    // path" task below (stored via `dotnet user-secrets`, outside the repo — never committed).
    // The `godot.executablePath` setting / GODOT env var still take precedence if set.
    "version": "2.0.0",
    "options": {
        "env": { "GODOT": "${config:godot.executablePath}" }
    },
    "tasks": [
        {
            "label": "Godot: import assets (if needed)",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File",
                "${workspaceFolder}/tools/godot-import.ps1"
            ],
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Godot: reimport assets (force)",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File",
                "${workspaceFolder}/tools/godot-import.ps1",
                "-Force"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run server",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File",
                "${workspaceFolder}/scripts/run-server.ps1"
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "run"
            },
            "problemMatcher": []
        },
        {
            "label": "Run client",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File",
                "${workspaceFolder}/scripts/run-client.ps1"
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "run"
            },
            "problemMatcher": []
        },
        {
            "label": "Export clients (all platforms)",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File",
                "${workspaceFolder}/scripts/export-clients.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            // Stores your machine's Godot path in the `dotnet user-secrets` store (outside the
            // repo, never committed). scripts/godot-bin.ps1 reads it back when resolving Godot.
            "label": "Godot: set executable path",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "user-secrets",
                "set",
                "godot.executablePath",
                "${input:godotPath}",
                "--id",
                "stellarallegiance"
            ],
            "presentation": {
                "reveal": "never",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Asteroid-gen: build catalog",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File",
                "${workspaceFolder}/tools/asteroid-gen/build.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "godotPath",
            "type": "promptString",
            "description": "Full path to the Godot 4 .NET (mono) executable (not a macOS .app folder)"
        }
    ]
}
