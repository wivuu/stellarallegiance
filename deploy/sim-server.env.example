# EnvironmentFile for the sim-server systemd unit. Copy to /etc/wivuullegiance/sim.env,
# fill in, and chmod 0640 (it holds secrets). See deploy/sim-server.service.

# Required: enables auth. Must match the secret installed via set_sim_endpoint.
# Generate: openssl rand -hex 32
SIM_SECRET=

# Match-result writeback to the self-hosted STDB node.
STDB_HTTP=http://127.0.0.1:3000
STDB_DB=stellar-allegiance
# Bearer token of the DB-owner identity (empty disables writeback).
STDB_TOKEN=
